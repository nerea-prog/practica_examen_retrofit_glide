<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:id="@+id/tvMode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="MODE: CREAR (POST)" android:textColor="#FFFFFF"
            android:textSize="14sp" android:textStyle="bold"
            android:background="#1565C0" android:padding="12dp" android:gravity="center"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Nom" android:textSize="14sp" android:textStyle="bold"
            android:textColor="#212121" android:layout_marginTop="20dp" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etNom" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Nom i cognoms..."
            android:inputType="textCapWords" android:background="#FFFFFF"
            android:padding="12dp" android:textSize="16sp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Feina / Job" android:textSize="14sp" android:textStyle="bold"
            android:textColor="#212121" android:layout_marginTop="16dp" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etFeina" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="p.ex. developer, designer..."
            android:inputType="textCapSentences" android:background="#FFFFFF"
            android:padding="12dp" android:textSize="16sp"/>

        <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_gravity="center"
            android:layout_marginTop="16dp" android:visibility="gone"/>

        <Button android:id="@+id/btnGuardar" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Crear usuari"
            android:textSize="16sp" android:layout_marginTop="20dp"
            android:backgroundTint="#1565C0"/>

        <!-- Targeta de resultat (visible després de l'operació) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResultat"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" app:cardCornerRadius="8dp"
            app:cardElevation="4dp" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp"
                android:background="#E8F5E9">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Resposta de l'API:" android:textStyle="bold"
                    android:textSize="14sp" android:textColor="#1B5E20"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvResultat" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:fontFamily="monospace"
                    android:textSize="13sp" android:textColor="#212121"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>