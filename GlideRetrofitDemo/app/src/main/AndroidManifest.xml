<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- IMPRESCINDIBLE: sense això Retrofit no pot fer cap petició -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.GlideRetrofitDemo"
        android:supportsRtl="true">

        <activity android:name=".ui.MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Detall usuari (CAS 2: GET per ID) -->
        <activity android:name=".ui.DetallActivity"/>

        <!-- Formulari crear/editar (CAS 4: POST / CAS 5: PUT) -->
        <activity android:name=".ui.FormActivity"/>

    </application>
</manifest>
